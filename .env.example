# SoniqMCP configuration example.
# Copy to .env and adjust values for your setup.
# All fields have safe defaults - only override what you need.

# Transport mode. "stdio" for local Claude Desktop use; "http" for remote/Docker deployment.
SONIQ_MCP_TRANSPORT=stdio

# HTTP transport settings (used when SONIQ_MCP_TRANSPORT=http).
# Use 0.0.0.0 when running in Docker or on a home-network host to allow port-mapped access.
SONIQ_MCP_HTTP_HOST=127.0.0.1
SONIQ_MCP_HTTP_PORT=8000

# Network exposure posture. "local" = trusted home network only.
SONIQ_MCP_EXPOSURE=local

# Log verbosity. One of: DEBUG, INFO, WARNING, ERROR
# Use DEBUG when setting up for the first time.
SONIQ_MCP_LOG_LEVEL=INFO

# Optional: default Sonos room name.
# Leave blank to require the AI agent to specify a room each time.
SONIQ_MCP_DEFAULT_ROOM=

# Volume safety cap (0-100). AI agents cannot set volume above this.
SONIQ_MCP_MAX_VOLUME_PCT=80

# Comma-separated tool names to disable at startup.
# Example: SONIQ_MCP_TOOLS_DISABLED=ping,server_info
SONIQ_MCP_TOOLS_DISABLED=

# Path to a config file (reserved for future use).
SONIQ_MCP_CONFIG_FILE=

# ---------------------------------------------------------------------------
# Optional HTTP authentication (applies to HTTP transport only; ignored on stdio).
# auth_mode=none is the default — no authentication is required.
# ---------------------------------------------------------------------------

# Static bearer token auth:
# SONIQ_MCP_AUTH_MODE=static
# SONIQ_MCP_AUTH_TOKEN=change-me-to-a-strong-secret

# OIDC JWT auth (requires a JWKS-capable identity provider, e.g. Authelia):
# SONIQ_MCP_AUTH_MODE=oidc
# SONIQ_MCP_OIDC_ISSUER=https://auth.example.com
# SONIQ_MCP_OIDC_AUDIENCE=https://soniq.example.com
# SONIQ_MCP_OIDC_JWKS_URI=          # optional; auto-discovered from issuer if unset
# SONIQ_MCP_OIDC_CA_BUNDLE=         # optional; path to private CA bundle file (OIDC verifier only)
# SONIQ_MCP_OIDC_RESOURCE_URL=      # optional; only if your IdP flow requires an explicit resource URL

# SSL_CERT_FILE augments the default Python TLS trust store for the entire process.
# This is distinct from SONIQ_MCP_OIDC_CA_BUNDLE, which is scoped to the OIDC verifier only.
# SSL_CERT_FILE=/etc/ssl/certs/ca-certificates.crt
