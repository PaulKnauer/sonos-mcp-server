# SoniqMCP configuration example.
# Copy to .env and adjust values for your setup.
# All fields have safe defaults; only override what you need.

# Transport mode. Currently only "stdio" is supported.
# Story 1.3 enables the stdio MCP server; Story 4.1 adds streamable-http.
SONIQ_MCP_TRANSPORT=stdio

# Network exposure posture. "local" restricts to trusted home network.
# Story 1.4 documents the full set of supported values.
SONIQ_MCP_EXPOSURE=local

# Log verbosity. One of: DEBUG, INFO, WARNING, ERROR
SONIQ_MCP_LOG_LEVEL=INFO

# Optional: default Sonos room name to target when no room is specified.
# Leave blank to require the AI agent to specify a room each time.
SONIQ_MCP_DEFAULT_ROOM=
